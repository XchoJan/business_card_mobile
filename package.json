{
  "name": "BusinessCard",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "i15": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 npx react-native run-ios --simulator='iPhone 15'",
    "i14": "LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 npx react-native run-ios --simulator='iPhone 14'",
    "pds": "cd ios && LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 pod install && cd ..",
    "aab": "react-native build-android --mode=release && open ./android/app/build/outputs/bundle/release",
    "apk": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle && cd ./android && ./gradlew app:assembleRelease && open ./app/build/outputs/apk/release",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.6",
    "@react-native/new-app-screen": "0.82.1",
    "@react-navigation/bottom-tabs": "^7.5.0",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/stack": "^7.4.10",
    "@reduxjs/toolkit": "^2.9.1",
    "axios": "^1.13.6",
    "lottie-react-native": "^7.3.4",
    "react": "19.1.1",
    "react-native": "0.82.1",
    "react-native-confirmation-code-field": "^8.0.1",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "^2.29.0",
    "react-native-international-phone-number": "^0.11.0",
    "react-native-maps": "^1.26.18",
    "react-native-mmkv": "^4.2.0",
    "react-native-modal": "^14.0.0-rc.1",
    "react-native-nitro-modules": "0.35.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.14.0",
    "react-native-worklets": "^0.6.1",
    "react-redux": "^9.2.0",
    "rn-vertical-slider": "^4.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.82.1",
    "@react-native/eslint-config": "0.82.1",
    "@react-native/metro-config": "0.82.1",
    "@react-native/typescript-config": "0.82.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.1",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.1",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
